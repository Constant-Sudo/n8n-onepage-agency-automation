      "position": [
        128,
        224
      ]
    },
    {
      "parameters": {
        "jsCode": "const base = ($('Prepare Base URL').first().json.base_url || '').replace(/\\/$/, '');\nconst raw = $json.data ?? $json.body ?? '';\nconst text = typeof raw === 'string' ? raw : JSON.stringify(raw);\nconst isXml = /<urlset|<sitemapindex/i.test(text);\nlet locs = [];\nif (isXml) {\n  locs = [...text.matchAll(/<loc>\\s*([^<\\s]+)\\s*<\\/loc>/gi)].map(m => m[1].trim());\n}\nreturn [{ json: { base_url: base, sitemap_found: isXml, sitemap_urls: locs } }];"
      },
